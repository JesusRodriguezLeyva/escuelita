{
  "name": "com.example.escuelita",
  "displayName": "escuelita",
  "version": "1.0.0",
  "description": "A sample Apache Cordova application that responds to the deviceready event.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Apache Cordova Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova-android": "^15.0.0",
    "cordova-browser": "^7.0.0",
    "cordova-plugin-firebasex": "^20.0.1"
  },
  "cordova": {
    "platforms": [
      "browser",
      "android"
    ],
    "plugins": {
      "cordova-plugin-firebasex": {
        "ANDROID_FIREBASE_CORE_VERSION": "21.1.1",
        "ANDROID_FIREBASE_INSTALLATIONS_VERSION": "18.0.0",
        "ANDROID_GSON_VERSION": "2.13.2",
        "IOS_FIREBASE_SDK_VERSION": "12.9.0",
        "IOS_FIREBASE_SDK_BETA_VERSION": "12.9.0-beta",
        "IOS_STRIP_DEBUG": "false",
        "ANDROID_FIREBASE_ANALYTICS_VERSION": "23.0.0",
        "ANDROID_PLAY_SERVICES_TAGMANAGER_VERSION": "18.3.0",
        "IOS_GOOGLE_TAG_MANAGER_VERSION": "9.0.0",
        "FIREBASE_ANALYTICS_COLLECTION_ENABLED": "true",
        "FIREBASE_ANALYTICS_WITHOUT_ADS": "false",
        "GOOGLE_ANALYTICS_ADID_COLLECTION_ENABLED": "true",
        "GOOGLE_ANALYTICS_DEFAULT_ALLOW_ANALYTICS_STORAGE": "true",
        "GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_STORAGE": "true",
        "GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_USER_DATA": "true",
        "GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_PERSONALIZATION_SIGNALS": "true",
        "IOS_ON_DEVICE_CONVERSION_ANALYTICS": "false",
        "ANDROID_FIREBASE_MESSAGING_VERSION": "25.0.1",
        "ANDROID_ICON_ACCENT": "#FFFFFF",
        "FIREBASE_FCM_AUTOINIT_ENABLED": "true",
        "FIREBASE_MESSAGING_IMMEDIATE_PAYLOAD_DELIVERY": "false",
        "IOS_FCM_ENABLED": "true",
        "IOS_ENABLE_CRITICAL_ALERTS_ENABLED": "false",
        "ANDROID_FIREBASE_AUTH_VERSION": "24.0.1",
        "ANDROID_PLAY_SERVICES_AUTH_VERSION": "21.5.1",
        "ANDROID_CREDENTIALS_VERSION": "1.5.0",
        "ANDROID_GOOGLEID_VERSION": "1.2.0",
        "SETUP_RECAPTCHA_VERIFICATION": "false",
        "IOS_ENABLE_APPLE_SIGNIN": "false",
        "IOS_GOOGLE_SIGIN_VERSION": "9.0.0",
        "ANDROID_FIREBASE_CRASHLYTICS_VERSION": "20.0.4",
        "ANDROID_FIREBASE_CRASHLYTICS_NDK_VERSION": "20.0.4",
        "FIREBASE_CRASHLYTICS_COLLECTION_ENABLED": "true",
        "ANDROID_FIREBASE_PERF_VERSION": "22.0.2",
        "FIREBASE_PERFORMANCE_COLLECTION_ENABLED": "true",
        "ANDROID_FIREBASE_PERFORMANCE_MONITORING": "false",
        "ANDROID_FIREBASE_PERF_GRADLE_PLUGIN_VERSION": "2.0.1",
        "ANDROID_FIREBASE_FIRESTORE_VERSION": "26.1.0",
        "ANDROID_GRPC_OKHTTP": "1.75.0",
        "IOS_USE_PRECOMPILED_FIRESTORE_POD": "false",
        "ANDROID_FIREBASE_FUNCTIONS_VERSION": "22.1.0",
        "ANDROID_FIREBASE_CONFIG_VERSION": "23.0.1",
        "ANDROID_FIREBASE_INAPPMESSAGING_VERSION": "22.0.2"
      }
    }
  }
}
